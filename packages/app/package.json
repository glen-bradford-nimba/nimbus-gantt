{
  "name": "@nimbus-gantt/app",
  "version": "0.185.33",
  "description": "Batteries-included NimbusGantt application shell",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "sideEffects": [
    "**/*.css",
    "./src/templates/cloudnimbus/index.ts",
    "./src/templates/cloudnimbus/index.vanilla.ts",
