{
  "name": "@nimbus-gantt/core",
  "version": "0.1.0",
  "description": "A high-performance, framework-agnostic Gantt chart library. MIT licensed.",
  "license": "MIT",
  "author": "Cloud Nimbus LLC",
  "repository": {
    "type": "git",
    "url": "https://github.com/cloudnimbusllc/nimbus-gantt"
  },
  "type": "module",
  "main": "dist/nimbus-gantt.umd.js",
  "module": "dist/nimbus-gantt.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/nimbus-gantt.es.js",
      "require": "./dist/nimbus-gantt.umd.js"
    },
    "./style.css": "./dist/nimbus-gantt.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "vite": "^6.0.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^3.0.0"
  }
}
